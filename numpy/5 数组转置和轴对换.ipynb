     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "arr = np.arange(15).reshape((3,5))\n",
    "print(arr)\n",
    "print(arr.transpose())  # transpose表示转置\n",
    "print(arr.T)    # T也表示转置"
   ]
  },
